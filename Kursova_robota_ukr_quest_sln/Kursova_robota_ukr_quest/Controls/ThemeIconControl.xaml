<UserControl x:Class="Kursova_robota_ukr_quest.Controls.ThemeIconControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="32" Height="32">
    <Grid>

        <!-- SUN (light mode) -->
        <Canvas x:Name="SunCanvas" Width="32" Height="32" Visibility="Visible">
            <!-- Circle -->
            <Ellipse Canvas.Left="9" Canvas.Top="9" Width="14" Height="14"
                     Fill="#F5A623" Stroke="#E8920A" StrokeThickness="1.5"/>
            <!-- 8 symmetric rays (mathematically calculated) -->
            <Line X1="16" Y1="8"   X2="16" Y2="2"     Stroke="#F5A623" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            <Line X1="21.66" Y1="10.34" X2="25.90" Y2="6.10"  Stroke="#F5A623" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            <Line X1="24" Y1="16"  X2="30" Y2="16"    Stroke="#F5A623" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            <Line X1="21.66" Y1="21.66" X2="25.90" Y2="25.90" Stroke="#F5A623" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            <Line X1="16" Y1="24"  X2="16" Y2="30"    Stroke="#F5A623" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            <Line X1="10.34" Y1="21.66" X2="6.10" Y2="25.90"  Stroke="#F5A623" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            <Line X1="8"  Y1="16"  X2="2"  Y2="16"    Stroke="#F5A623" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            <Line X1="10.34" Y1="10.34" X2="6.10" Y2="6.10"   Stroke="#F5A623" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
        </Canvas>

        <!-- MOON (dark mode) -->
        <Grid x:Name="MoonCanvas" Width="32" Height="32" Visibility="Collapsed">
            <Path Fill="#FFFFFF">
                <Path.Data>
                    <CombinedGeometry GeometryCombineMode="Exclude">
                        <!-- Large circle (main moon body) -->
                        <CombinedGeometry.Geometry1>
                            <EllipseGeometry Center="14,16" RadiusX="11" RadiusY="11"/>
                        </CombinedGeometry.Geometry1>
                        <!-- Smaller offset circle (cuts out crescent) -->
                        <CombinedGeometry.Geometry2>
                            <EllipseGeometry Center="19,16" RadiusX="9" RadiusY="9"/>
                        </CombinedGeometry.Geometry2>
                    </CombinedGeometry>
                </Path.Data>
            </Path>
            <!-- Star -->
            <Ellipse Width="3" Height="3" Fill="#FFFFFF"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,5,3,0"/>
        </Grid>

    </Grid>
</UserControl>
