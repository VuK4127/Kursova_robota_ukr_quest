<Page x:Class="Kursova_robota_ukr_quest.Views.ModePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Режим гри">

    <Grid Background="{DynamicResource WindowBackground}">
        <Border Style="{StaticResource CardStyle}"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                MinWidth="320" MaxWidth="400" Margin="20">
            <StackPanel>

                <TextBlock Text="Оберіть режим" FontSize="28" FontWeight="Bold"
                           FontFamily="Helvetica Neue, Arial, sans-serif"
                           Foreground="{DynamicResource MainTextBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,28"/>

                <Button Content="ГРАМАТИКА" Style="{StaticResource MainButtonStyle}"
                        Background="#1A73E8" Width="260" Margin="0,0,0,12"
                        Click="Classic_Click"/>

                <Button Content="ВОРДЛ" Style="{StaticResource MainButtonStyle}"
                        Background="#34A853" Width="260" Margin="0,0,0,12"
                        Click="Wordle_Click"/>

                <Button Content="ПУНКТУАЦІЯ" Style="{StaticResource MainButtonStyle}"
                        Background="#E67C13" Width="260" Margin="0,0,0,20"
                        Click="Punctuation_Click"/>

                <Button Content="НАЗАД" Style="{StaticResource ExitButtonStyle}"
                        Width="260" Click="Back_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Page>
