<Page x:Class="Kursova_robota_ukr_quest.Views.GamePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:Kursova_robota_ukr_quest.ViewModels"
      Title="Граматика">

    <Grid Background="{DynamicResource WindowBackground}">
        <Border Style="{StaticResource CardStyle}"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                MinWidth="320" MaxWidth="420" Margin="20">
            <StackPanel>

                <!-- Header: progress -->
                <Border Background="{DynamicResource CardBackgroundAlt}" CornerRadius="8"
                        Padding="14,10" Margin="0,0,0,20">
                    <DockPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="LevelLabel" Text="Рівень 1"
                                       FontFamily="Helvetica Neue, Arial, sans-serif"
                                       Foreground="{DynamicResource MainTextBrush}"
                                       FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ProgressText" Text=" · 1/10"
                                       FontFamily="Helvetica Neue, Arial, sans-serif"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="CorrectText" Text="✔ 0"
                                   FontFamily="Helvetica Neue, Arial, sans-serif"
                                   Foreground="#34A853" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- Question -->
                <TextBlock Text="{Binding CurrentText}" FontSize="19"
                           FontFamily="Helvetica Neue, Arial, sans-serif"
                           Foreground="{DynamicResource MainTextBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,20" TextAlignment="Center"/>

                <!-- Answer input -->
                <TextBox x:Name="AnswerInput"
                         Margin="0,0,0,10" KeyDown="AnswerInput_KeyDown"/>

                <!-- Status -->
                <TextBlock x:Name="StatusText" FontSize="15" FontWeight="Bold"
                           FontFamily="Helvetica Neue, Arial, sans-serif"
                           HorizontalAlignment="Center" Margin="0,0,0,16"
                           TextWrapping="Wrap" TextAlignment="Center"/>

                <!-- Check / Next -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Button x:Name="CheckBtn" Content="ПЕРЕВІРИТИ" Click="CheckBtn_Click"
                            Style="{StaticResource MainButtonStyle}" Background="#34A853"
                            Width="140" Margin="0,0,10,0"/>
                    <Button x:Name="NextBtn" Content="НАСТУПНЕ" Click="NextBtn_Click"
                            Style="{StaticResource MainButtonStyle}" Background="#FBBC05"
                            Width="140" IsEnabled="False"/>
                </StackPanel>

                <!-- Back -->
                <Button Content="НАЗАД" Style="{StaticResource ExitButtonStyle}"
                        Width="290" Click="Exit_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Page>
