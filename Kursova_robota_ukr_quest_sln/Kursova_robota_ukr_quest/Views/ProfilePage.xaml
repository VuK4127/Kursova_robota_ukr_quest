<Page x:Class="Kursova_robota_ukr_quest.Views.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Профіль">

    <Grid Background="{DynamicResource WindowBackground}">
        <Border Style="{StaticResource CardStyle}"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                MinWidth="320" MaxWidth="400" Margin="20">
            <StackPanel>

                <TextBlock Text="Профіль" FontSize="28" FontWeight="Bold"
                           FontFamily="Helvetica Neue, Arial, sans-serif"
                           Foreground="{DynamicResource MainTextBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <Ellipse Width="100" Height="100" HorizontalAlignment="Center" Margin="0,0,0,12">
                    <Ellipse.Fill>
                        <ImageBrush x:Name="AvatarBrush" Stretch="UniformToFill"/>
                    </Ellipse.Fill>
                </Ellipse>

                <Button Content="ЗМІНИТИ АВАТАР" Style="{StaticResource MainButtonStyle}"
                        Background="#6C757D" Width="260" Margin="0,0,0,20"
                        HorizontalAlignment="Center" Click="ChangeAvatar_Click"/>

                <TextBlock Text="Нікнейм" FontSize="13" FontWeight="SemiBold"
                           FontFamily="Helvetica Neue, Arial, sans-serif"
                           Foreground="{DynamicResource SubtleText}" Margin="0,0,0,6"/>

                <TextBox x:Name="NicknameBox" Margin="0,0,0,20"/>

                <Button Content="ЗБЕРЕГТИ" Style="{StaticResource MainButtonStyle}"
                        Background="#34A853" Margin="0,0,0,10" Click="Save_Click"/>

                <Button Content="НАЗАД" Style="{StaticResource ExitButtonStyle}"
                        Click="Back_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Page>
