<Page x:Class="Kursova_robota_ukr_quest.Views.MenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ctrl="clr-namespace:Kursova_robota_ukr_quest.Controls"
      Title="Меню"
      Loaded="Page_Loaded">

    <Grid Background="{DynamicResource WindowBackground}">

        <!-- Top-left: theme toggle -->
        <Button x:Name="ThemeBtn" Style="{StaticResource IconButtonStyle}"
                VerticalAlignment="Top" HorizontalAlignment="Left"
                Margin="16,12,0,0"
                Click="ThemeToggle_Click">
            <ctrl:ThemeIconControl x:Name="ThemeIcon"/>
        </Button>

        <!-- Top-right: profile icon + nickname -->
        <Button Style="{StaticResource IconButtonStyle}"
                VerticalAlignment="Top" HorizontalAlignment="Right"
                Margin="0,12,16,0"
                Click="Profile_Click">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="28" Height="28" Margin="0,0,6,0">
                    <Ellipse.Fill>
                        <ImageBrush x:Name="TopAvatarBrush" Stretch="UniformToFill"/>
                    </Ellipse.Fill>
                </Ellipse>
                <TextBlock x:Name="TopNickname" FontSize="13"
                           FontFamily="Helvetica Neue, Arial, sans-serif"
                           Foreground="{DynamicResource MainTextBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Button>

        <!-- Center card -->
        <Border Style="{StaticResource CardStyle}"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                MinWidth="320" MaxWidth="400" Margin="20">
            <StackPanel>
                <TextBlock Text="Мовний квест" FontSize="28" FontWeight="Bold"
                           FontFamily="Helvetica Neue, Arial, sans-serif"
                           Foreground="{DynamicResource MainTextBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>

                <TextBlock x:Name="RoleBadge" FontSize="12" HorizontalAlignment="Center"
                           Foreground="{DynamicResource SubtleText}" Margin="0,0,0,20"/>

                <Button Content="ПОЧАТИ ГРУ" Style="{StaticResource MainButtonStyle}"
                        Background="#1A73E8" Width="260" Margin="0,0,0,12"
                        Click="Play_Click"/>

                <!-- Admin-only button — hidden for regular users -->
                <Button x:Name="AdminBtn"
                        Content="⚙ АДМІН-ПАНЕЛЬ" Style="{StaticResource MainButtonStyle}"
                        Background="#E67C13" Width="260" Margin="0,0,0,12"
                        Visibility="Collapsed"
                        Click="Admin_Click"/>

                <Button Content="ВИЙТИ" Style="{StaticResource ExitButtonStyle}"
                        Width="260" Margin="0"
                        Click="Exit_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
