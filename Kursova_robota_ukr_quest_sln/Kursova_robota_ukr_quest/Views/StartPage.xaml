<Page x:Class="Kursova_robota_ukr_quest.Views.StartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ctrl="clr-namespace:Kursova_robota_ukr_quest.Controls"
      Title="StartPage">

    <Grid Background="{DynamicResource WindowBackground}">

        <!-- Top-left: theme toggle -->
        <Button x:Name="ThemeBtn" Style="{StaticResource IconButtonStyle}"
                VerticalAlignment="Top" HorizontalAlignment="Left"
                Margin="16,12,0,0"
                Click="ThemeToggle_Click">
            <ctrl:ThemeIconControl x:Name="ThemeIcon"/>
        </Button>

        <!-- Top-right: profile icon -->
        <Button Style="{StaticResource IconButtonStyle}"
                VerticalAlignment="Top" HorizontalAlignment="Right"
                Margin="0,12,16,0"
                Click="Profile_Click">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="👤" FontSize="20" VerticalAlignment="Center"/>
                <TextBlock Text=" Профіль" FontSize="13" FontFamily="Helvetica Neue, Arial, sans-serif"
                           Foreground="{DynamicResource MainTextBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>

        <!-- Center content -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="280">

            <TextBlock Text="Мовний квест" FontSize="28" FontWeight="Bold"
                       FontFamily="Helvetica Neue, Arial, sans-serif"
                       Foreground="{DynamicResource MainTextBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>

            <TextBlock Text="Перевір свої знання української мови"
                       FontSize="14" FontFamily="Helvetica Neue, Arial, sans-serif"
                       Foreground="{DynamicResource SubtleText}"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       Margin="0,0,0,40" TextWrapping="Wrap"/>

            <Button Content="ПОЧАТИ ГРУ" Style="{StaticResource MainButtonStyle}"
                    Background="#1A73E8" Width="280" Margin="0,0,0,12"
                    Click="Start_Click"/>

            <Button Content="ВИЙТИ" Style="{StaticResource ExitButtonStyle}"
                    Width="280" Margin="0"
                    Click="Exit_Click"/>

        </StackPanel>
    </Grid>
</Page>
