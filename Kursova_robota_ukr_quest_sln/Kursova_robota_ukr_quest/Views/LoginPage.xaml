<Page x:Class="Kursova_robota_ukr_quest.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Вхід">

    <Grid Background="{DynamicResource WindowBackground}">
        <Border Style="{StaticResource CardStyle}"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                MinWidth="320" MaxWidth="380" Margin="20">
            <StackPanel>

                <TextBlock Text="🔐 Вхід" FontSize="26" FontWeight="Bold"
                           FontFamily="Helvetica Neue, Arial, sans-serif"
                           Foreground="{DynamicResource MainTextBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <!-- Логін -->
                <TextBlock Text="Логін" FontSize="13"
                           Foreground="{DynamicResource SubtleText}" Margin="0,0,0,4"/>
                <TextBox x:Name="LoginBox" Margin="0,0,0,14" KeyDown="Input_KeyDown"/>

                <!-- Пароль -->
                <TextBlock Text="Пароль" FontSize="13"
                           Foreground="{DynamicResource SubtleText}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox" Margin="0,0,0,8" KeyDown="Input_KeyDown"/>

                <!-- Помилка -->
                <TextBlock x:Name="ErrorText" FontSize="13" Foreground="#EA4335"
                           HorizontalAlignment="Center" Margin="0,0,0,4" Text=""/>

                <!-- Спроби -->
                <TextBlock x:Name="AttemptsText" FontSize="12"
                           Foreground="{DynamicResource SubtleText}"
                           HorizontalAlignment="Center" Margin="0,0,0,14" Text=""/>

                <Button Content="УВІЙТИ" Style="{StaticResource MainButtonStyle}"
                        Background="#1A73E8" Width="280" Margin="0,0,0,10"
                        Click="Login_Click"/>

                <Button Content="Немає акаунту? Зареєструватись"
                        Style="{StaticResource ExitButtonStyle}"
                        Width="280"
                        Click="GoRegister_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Page>
