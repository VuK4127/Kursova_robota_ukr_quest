<Page x:Class="Kursova_robota_ukr_quest.Views.LevelSelectPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Вибір рівня">

    <Grid Background="{DynamicResource WindowBackground}">
        <Border Style="{StaticResource CardStyle}"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                MinWidth="320" MaxWidth="420" Margin="20">
            <StackPanel>

                <TextBlock x:Name="TitleText" Text="Оберіть рівень"
                           FontSize="24" FontWeight="Bold"
                           FontFamily="Helvetica Neue, Arial, sans-serif"
                           Foreground="{DynamicResource MainTextBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,6"/>

                <TextBlock Text="Кожен рівень містить 10 питань"
                           FontSize="13" FontFamily="Helvetica Neue, Arial, sans-serif"
                           Foreground="{DynamicResource SubtleText}"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <!-- Level grid 2x5 -->
                <UniformGrid x:Name="LevelGrid" Columns="2" Margin="0,0,0,16"/>

                <Button Content="НАЗАД" Style="{StaticResource ExitButtonStyle}"
                        Width="310" Click="Back_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Page>
