<Page x:Class="Kursova_robota_ukr_quest.Views.PunctuationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Пунктуація">

    <Grid Background="{DynamicResource WindowBackground}">

        <Border Style="{StaticResource CardStyle}"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                MinWidth="460" MaxWidth="640" Margin="20">
            <StackPanel>

                <!-- Header: progress + score -->
                <Border Background="{DynamicResource CardBackgroundAlt}" CornerRadius="8"
                        Padding="14,10" Margin="0,0,0,20">
                    <DockPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔤" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock x:Name="ProgressText" Text="1 / 10"
                                       FontFamily="Helvetica Neue, Arial, sans-serif"
                                       Foreground="{DynamicResource MainTextBrush}"
                                       FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="ScoreText" Text="Бали: 0"
                                   FontFamily="Helvetica Neue, Arial, sans-serif"
                                   Foreground="#E67C13" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- Hint label -->
                <TextBlock Text="Де поставити розділовий знак?"
                           FontSize="13" FontFamily="Helvetica Neue, Arial, sans-serif"
                           Foreground="{DynamicResource SubtleText}"
                           HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <!-- Sentence with clickable gaps -->
                <Border Background="{DynamicResource CardBackgroundAlt}" CornerRadius="10"
                        Padding="16,14" Margin="0,0,0,18">
                    <ItemsControl x:Name="SentencePanel">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </Border>

                <!-- Punctuation buttons -->
                <TextBlock Text="Оберіть знак:"
                           FontSize="13" FontFamily="Helvetica Neue, Arial, sans-serif"
                           Foreground="{DynamicResource SubtleText}"
                           HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,18">
                    <Button x:Name="BtnComma"   Content=","  Tag=","  Click="PunctBtn_Click"
                            Style="{StaticResource PunctButtonStyle}" Margin="4"/>
                    <Button x:Name="BtnPeriod"  Content="."  Tag="."  Click="PunctBtn_Click"
                            Style="{StaticResource PunctButtonStyle}" Margin="4"/>
                    <Button x:Name="BtnDash"    Content="—"  Tag="—"  Click="PunctBtn_Click"
                            Style="{StaticResource PunctButtonStyle}" Margin="4"/>
                    <Button x:Name="BtnColon"   Content=":"  Tag=":"  Click="PunctBtn_Click"
                            Style="{StaticResource PunctButtonStyle}" Margin="4"/>
                    <Button x:Name="BtnExcl"    Content="!"  Tag="!"  Click="PunctBtn_Click"
                            Style="{StaticResource PunctButtonStyle}" Margin="4"/>
                    <Button x:Name="BtnQuestion" Content="?" Tag="?"  Click="PunctBtn_Click"
                            Style="{StaticResource PunctButtonStyle}" Margin="4"/>
                    <Button x:Name="BtnSemicolon" Content=";" Tag=";" Click="PunctBtn_Click"
                            Style="{StaticResource PunctButtonStyle}" Margin="4"/>
                    <Button x:Name="BtnNone"    Content="∅"  Tag=""   Click="PunctBtn_Click"
                            Style="{StaticResource PunctButtonStyle}" Margin="4"/>
                </WrapPanel>

                <!-- Status feedback -->
                <Border x:Name="FeedbackBorder" CornerRadius="8" Padding="12,8"
                        Margin="0,0,0,16" Visibility="Collapsed">
                    <TextBlock x:Name="StatusText" FontSize="14" FontWeight="Bold"
                               FontFamily="Helvetica Neue, Arial, sans-serif"
                               HorizontalAlignment="Center" TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </Border>

                <!-- Action buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="CheckBtn" Content="ПЕРЕВІРИТИ" Click="CheckBtn_Click"
                            Style="{StaticResource MainButtonStyle}" Background="#34A853"
                            Width="150" Margin="0,0,10,0"/>
                    <Button x:Name="NextBtn" Content="НАСТУПНЕ" Click="NextBtn_Click"
                            Style="{StaticResource MainButtonStyle}" Background="#1A73E8"
                            Width="150" IsEnabled="False"/>
                </StackPanel>

                <Button Content="НАЗАД" Style="{StaticResource ExitButtonStyle}"
                        Width="310" Margin="0,12,0,0" Click="Back_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Page>
